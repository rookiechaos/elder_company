# Environment template — copy to do-not-upload/env/.env and fill in values.
#   cp backend/env.example do-not-upload/env/.env
#
# Local data (DB, logs, uploads) lives under do-not-upload/ (gitignored).
# Defaults are set in backend/utils/local_paths.py if these are omitted.

# Database (optional — default: do-not-upload/data/elder_company.db)
# DATABASE_URL=sqlite:////absolute/path/to/do-not-upload/data/elder_company.db

# Local file storage (optional — default: do-not-upload/storage)
# STORAGE_DIR=../do-not-upload/storage

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI Provider Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_API_KEY=your_google_api_key

# Embedding Configuration
# OPENAI_API_KEY is used for embeddings (text-embedding-3-small)

# Push Notification (FCM)
FCM_SERVER_KEY=your_fcm_server_key

# Email Notification (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
FROM_EMAIL=your_email@example.com
FROM_NAME=Elder Company

# SMS Notification (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Organization Configuration
DEFAULT_ORG_ID=default_org
ORG_SUBSCRIPTION_PLAN=basic
ORG_MAX_USERS=10
ORG_MONTHLY_TRANSLATION_LIMIT=1000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis Configuration (Optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development
DEBUG=true
TEST_MODE=false

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
